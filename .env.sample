# Copy to .env and fill in values. Loaded by the devcontainer via docker
# --env-file, which only supports single-line KEY=VALUE pairs — encode the
# multi-line PEM files as base64 (e.g. `base64 -w0 cert.pem`).
# Used by the live integration/smoke tests only; never commit .env.

# ADP API credentials (client-credentials grant)
ADP_CLIENT_ID=
ADP_CLIENT_SECRET=

# mTLS client certificate and private key, base64-encoded PEM
ADP_CERTIFICATE=
ADP_PRIVATE_KEY=

# Optional: a known associateOID for read-only integration tests (worker.one)
ADP_ASSOCIATE_OID=
